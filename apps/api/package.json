{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --sourcemap --clean --out-dir dist",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma": "prisma",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "keys:generate": "tsx scripts/generate-jwt-keys.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@monceri/shared": "workspace:*",
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.6.1",
    "pino": "^10.1.0",
    "sharp": "^0.34.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@monceri/eslint-config": "workspace:*",
    "@types/node": "^24.9.2",
    "eslint": "^9.39.1",
    "prisma": "^6.18.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
